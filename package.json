{
  "name": "flowybooks",
  "version": "0.1.0",
  "description": "A local-first bookkeeping app for accounts, journals, reports, and statement imports.",
  "license": "Apache-2.0",
  "private": false,
  "homepage": "https://github.com/flowybooks/flowybooks#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flowybooks/flowybooks.git"
  },
  "bugs": {
    "url": "https://github.com/flowybooks/flowybooks/issues"
  },
  "keywords": [
    "accounting",
    "bookkeeping",
    "local-first",
    "pglite",
    "ledger",
    "nextjs"
  ],
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20.9.0"
  },
  "packageManager": "bun@1.3.4",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.mts",
    "test:e2e": "playwright test",
    "test:deadcode": "knip --no-progress --include files,dependencies --no-config-hints",
    "test:coverage:core": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest",
    "ai:smoke:ollama": "bun scripts/kevin-smoke-ollama.ts",
    "ai:eval:ollama-models": "bun scripts/kevin-eval-ollama-models.ts",
    "kevin:index:local": "bun scripts/kevin-index-local-documents.ts",
    "arch:check": "bun scripts/architecture-check.ts",
    "release:scan": "bun scripts/release-scan.ts",
    "migration:check": "bun scripts/migration-check.ts",
    "release:check": "bun run verify && bun audit && bun run migration:check && bun run release:scan",
    "format": "prettier --check \"app/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"scripts/**/*.ts\" \"test/**/*.ts\"",
    "verify": "bun run format && bun run arch:check && bun run lint && bun run typecheck && bun run test && bun run test:integration && bun run test:coverage:core && bun run test:deadcode && bun run build && bun run test:e2e",
    "db:setup": "bun lib/db/setup.ts",
    "db:seed": "bun lib/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate && bun scripts/migrate-auth.ts",
    "db:studio": "drizzle-kit studio",
    "record:walkthrough": "bun scripts/record-walkthrough.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "@electric-sql/pglite": "^0.4.6",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "4.1.17",
    "@types/node": "^22.19.11",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.5",
    "ai": "^6.0.185",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.2",
    "kysely": "^0.29.2",
    "lucide-react": "^0.562.0",
    "next": "16.2.9",
    "pdf-parse": "1.1.1",
    "postcss": "8.5.14",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.14",
    "qs": "6.14.1"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.2.9",
    "@playwright/test": "^1.58.2",
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "^9.39.2",
    "knip": "5.88.1",
    "prettier": "3.8.4",
    "vitest": "4.1.8"
  }
}
