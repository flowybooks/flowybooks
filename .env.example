# Copy to .env and adjust values for your machine.

# Durable local embedded PGlite Postgres data directory.
# Must be a filesystem path. Do not use :memory: or memory:// for books.
PGLITE_DATA_DIR=.pglite/flowybooks

# Required app/auth URLs.
BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-generate-a-long-random-secret
BETTER_AUTH_TRUSTED_ORIGINS=

# Optional cleanup cron endpoint secret.
CRON_SECRET=change-me-generate-a-long-random-secret

# Optional AI. Leave AI_PROVIDER blank to keep AI disabled.
# Supported providers: ollama, openai.
AI_PROVIDER=

# Optional local AI with Ollama. No external AI account is required.
# Run `ollama pull gemma4:26b-mlx`, then set AI_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:26b-mlx

# Optional Kevin model tiers for Ollama. The local-only default is Gemma 4 26B MLX.
KEVIN_OLLAMA_SMALL_MODEL=gemma4:26b-mlx
KEVIN_OLLAMA_MEDIUM_MODEL=gemma4:26b-mlx
KEVIN_OLLAMA_LARGE_MODEL=gemma4:26b-mlx

# Optional OpenAI hosted/API mode.
OPENAI_API_KEY=

# Optional OpenAI model overrides.
OPENAI_MODEL=gpt-5-mini
# Kevin OpenAI defaults are gpt-5-nano, gpt-5-mini, and gpt-5.5.
# Kevin sends extra-high reasoning effort for OpenAI large-tier calls.
KEVIN_OPENAI_SMALL_MODEL=
KEVIN_OPENAI_MEDIUM_MODEL=
KEVIN_OPENAI_LARGE_MODEL=

# Optional constrained authority and local document settings.
FLOWYBOOKS_USER_AGENT=flowybooks-local/0.1
LOCAL_AGENT_FILES_DIR=
KEVIN_INDEX_ORG_ID=
